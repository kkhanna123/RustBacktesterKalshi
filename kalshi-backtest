#!/usr/bin/env bash
# kalshi-backtest — convenience launcher for the Rust tick-level Kalshi backtester.
#
# Builds the release binary on first use (or after a source change), then execs it, forwarding
# every argument. From the repo root you can just run, e.g.:
#
#   ./kalshi-backtest --help
#   ./kalshi-backtest list-strategies
#   ./kalshi-backtest backtest --config run.toml
#
# Set KALSHI_BT_FEATURES to pass cargo features (e.g. KALSHI_BT_FEATURES=clickhouse) so the
# ClickHouse source is compiled in:  KALSHI_BT_FEATURES=clickhouse ./kalshi-backtest backtest ...
set -euo pipefail

# Resolve the directory this script lives in (repo root), independent of the caller's CWD.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CRATE_DIR="$SCRIPT_DIR/backtester"
BIN="$CRATE_DIR/target/release/kalshi-backtest"

FEATURE_ARGS=()
if [[ -n "${KALSHI_BT_FEATURES:-}" ]]; then
  FEATURE_ARGS=(--features "$KALSHI_BT_FEATURES")
fi

# Build if the binary is missing. (cargo is fast to no-op when already up to date, so we also
# rebuild to pick up source changes; build chatter goes to STDERR so STDOUT stays clean.)
if [[ ! -x "$BIN" ]]; then
  echo "[kalshi-backtest] building release binary (first run)..." >&2
fi
# Expand FEATURE_ARGS safely even when empty (macOS bash 3.2 + `set -u`).
( cd "$CRATE_DIR" && cargo build --release ${FEATURE_ARGS[@]+"${FEATURE_ARGS[@]}"} ) >&2

exec "$BIN" "$@"
